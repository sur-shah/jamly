{
  "expo": {
    "name": "Jamly",
    "slug": "jamly",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "jamly",
    "splash": {
      "backgroundColor": "#F7F4EE"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F4EE"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiUrl": "http://127.0.0.1:8000"
    }
  }
}
